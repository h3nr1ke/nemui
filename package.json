{
  "name": "nemui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:standalone": "cd packages/standalone && npm run dev",
    "build:standalone": "cd packages/standalone && npm run build",
    "dev:electron": "cd packages/electron && npm run dev",
    "build:electron": "cd packages/electron && npm run build",
    "build:electron:win": "cd packages/electron && npm run build:win",
    "build:electron:mac": "cd packages/electron && npm run build:mac",
    "build:electron:linux": "cd packages/electron && npm run build:linux",
    "dev:vscode": "cd packages/vscode && npm run dev",
    "build:vscode": "cd packages/vscode && npm run compile && cp -r ../standalone/dist/* webview/",
    "package:vscode": "cd packages/vscode && npm run package",
    "build": "npm run build:standalone && npm run build:vscode && npm run build:electron"
  }
}
