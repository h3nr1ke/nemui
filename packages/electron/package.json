{
  "name": "@nemui/electron",
  "version": "1.0.0",
  "description": "Nemui API Client - Desktop App",
  "main": "dist-electron/main.js",
  "author": "Nemui",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:main && electron .",
    "build": "npm run build:main && electron-builder",
    "build:main": "tsc main.ts --outDir dist-electron --module CommonJS --target ES2020 --esModuleInterop --skipLibCheck"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0"
  },
  "build": {
    "appId": "com.nemui.app",
    "productName": "Nemui API Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "webview/**/*"
    ],
    "extraResources": [
      {
        "from": "../standalone/dist",
        "to": "webview"
      }
    ],
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  }
}
